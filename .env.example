# Dribbble profile to track (used by the server and `npm run scrape`)
PROFILE_URL=https://dribbble.com/helistudio
MAX_SHOTS=200

# Server port (hosting platforms may inject their own PORT)
PORT=3000

# Optional in-process daily cron (NOT needed if you use the GitHub Actions
# workflow at .github/workflows/daily-scrape.yml — that is the recommended way)
ENABLE_CRON=false
CRON_SCHEDULE=50 23 * * *
# CRON_TZ=Asia/Tehran
